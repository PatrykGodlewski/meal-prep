# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Feature flags
NEXT_PUBLIC_SIGN_UP_ENABLED=false

# RAG meal generation (set in Convex Dashboard > Settings > Environment Variables)
# Generation (free): Groq – https://console.groq.com/keys
# GROQ_API_KEY=
# Embeddings (free): Google AI – https://aistudio.google.com/apikey
# GOOGLE_GENERATIVE_AI_API_KEY=
# Food image for generated meals (optional): Replicate – https://replicate.com/account/api-tokens
# REPLICATE_API_TOKEN=

# Resend (for password reset emails; optional until integrated)
# AUTH_RESEND_KEY=re_xxx
